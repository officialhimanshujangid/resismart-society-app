{
  "expo": {
    "name": "ResiSmart Society",
    "slug": "resismart-society",
    "version": "1.0.0",
    "scheme": "resismart-society",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "sdkVersion": "54.0.0",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F2D5C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.resismart.society"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0F2D5C"
      },
      "package": "com.resismart.society"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
